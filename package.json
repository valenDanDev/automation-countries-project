{
  "name": "automation-countries-project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open --e2e --browser chrome",
    "cy:run": "cypress run --browser chrome",
    "cy:headed": "cypress run --headed",
    "report:merge": "npx mochawesome-merge \"cypress/reports/mochawesome*.json\" > cypress/reports/report.json",
    "report:generate": "powershell -Command \"mkdir -Force cypress/reports/final-reports; npx marge cypress/reports/report.json -f report-$(Get-Date -Format yyyy-MM-dd_HH-mm-ss) -o cypress/reports/final-reports\"",
    "report:clean": "del cypress\\reports\\mochawesome*.json && del cypress\\reports\\report.json 2>nul",
    "test:report": "npm run report:clean && npm run cy:run && npm run report:merge && npm run report:generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valenDanDev/automation-countries-project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/valenDanDev/automation-countries-project/issues"
  },
  "homepage": "https://github.com/valenDanDev/automation-countries-project#readme",
  "devDependencies": {
    "cypress": "^15.13.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^5.2.0"
  }
}
